# ──────────────────────────────────────────────────────────────
# Clara Answers Pipeline – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── LLM Provider ───────────────────────────────────────────────
# Options: groq | gemini | ollama
LLM_PROVIDER=groq

# ── Groq (FREE tier – https://console.groq.com) ────────────────
# Sign up free, no credit card needed for basic usage
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (FREE tier – https://aistudio.google.com) ────
# 15 requests/min free. Get key at aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Ollama (fully local – no API key needed) ───────────────────
# Install: https://ollama.com  then: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── GitHub Task Tracker (optional, FREE) ───────────────────────
# Create a Personal Access Token with 'repo' scope at:
# https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=yourname/clara-pipeline
